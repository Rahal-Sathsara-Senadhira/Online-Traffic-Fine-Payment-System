{
  "info": {
    "name": "Traffic Fine Payment API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:4000/api" },
    { "key": "token",    "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "  console.log('Token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Register Admin (requires token)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin2\",\n  \"password\": \"admin123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Fines",
      "item": [
        {
          "name": "Get Fine by Reference (public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/fines/TF-2026-100001"
          }
        },
        {
          "name": "Get Fine — PAID example",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/fines/TF-2026-100002"
          }
        },
        {
          "name": "Get Fine — Not Found",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/fines/TF-0000-000000"
          }
        },
        {
          "name": "Get All Fines (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/fines"
          }
        },
        {
          "name": "Get All Fines — filter PENDING (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/fines?status=PENDING",
              "query": [{ "key": "status", "value": "PENDING" }]
            }
          }
        },
        {
          "name": "Create Fine (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/fines",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"REPLACE_WITH_CATEGORY_ID\",\n  \"officerId\": \"REPLACE_WITH_OFFICER_ID\",\n  \"driverNic\": \"200012345678\",\n  \"driverName\": \"Test Driver\",\n  \"vehicleNumber\": \"CAB-0001\",\n  \"location\": \"Baseline Road, Colombo\",\n  \"amount\": 2500.00\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Pay Fine — PENDING (success)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceNumber\": \"TF-2026-100001\",\n  \"categoryId\": \"REPLACE_WITH_CATEGORY_ID\",\n  \"paymentMethod\": \"CARD\"\n}"
            }
          }
        },
        {
          "name": "Pay Fine — Already PAID (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceNumber\": \"TF-2026-100002\",\n  \"categoryId\": \"REPLACE_WITH_CATEGORY_ID\",\n  \"paymentMethod\": \"CARD\"\n}"
            }
          }
        },
        {
          "name": "Pay Fine — Wrong Category (422)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceNumber\": \"TF-2026-100003\",\n  \"categoryId\": \"00000000-0000-0000-0000-000000000000\",\n  \"paymentMethod\": \"CARD\"\n}"
            }
          }
        },
        {
          "name": "Pay Fine — Ref Not Found (404)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceNumber\": \"TF-0000-000000\",\n  \"categoryId\": \"00000000-0000-0000-0000-000000000000\",\n  \"paymentMethod\": \"CARD\"\n}"
            }
          }
        },
        {
          "name": "Pay Fine — Validation Error (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentMethod\": \"INVALID_METHOD\"\n}"
            }
          }
        },
        {
          "name": "Get Payment Receipt",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/payments/REPLACE_WITH_PAYMENT_ID"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories (public)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/categories"
          }
        },
        {
          "name": "Create Category (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Overloading\",\n  \"description\": \"Vehicle exceeds the maximum load limit\",\n  \"defaultAmount\": 4000.00\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Officers",
      "item": [
        {
          "name": "Get All Officers (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/officers"
          }
        },
        {
          "name": "Create Officer (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/officers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"badgeNumber\": \"PC-2001\",\n  \"fullName\": \"Samantha Gunawardena\",\n  \"phone\": \"0779001122\",\n  \"district\": \"Colombo\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Summary (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/reports/summary"
          }
        },
        {
          "name": "District Breakdown (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/reports/districts"
          }
        },
        {
          "name": "Category Breakdown (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/reports/categories"
          }
        }
      ]
    },
    {
      "name": "Auth Errors",
      "item": [
        {
          "name": "No Token (401)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reports/summary"
          }
        },
        {
          "name": "Invalid Token (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer this.is.not.valid" }],
            "url": "{{base_url}}/reports/summary"
          }
        },
        {
          "name": "Wrong Credentials (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}"
            }
          }
        }
      ]
    }
  ]
}
